# === Neon PostgreSQL ===
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# === Vercel Blob ===
VERCEL_BLOB_TOKEN=vercel_blob_rw_xxx

# === Telegram ===
TELEGRAM_BOT_TOKEN=1234567890:AAF-xxx
TELEGRAM_CHAT_ID=123456789

# === Webhook-сервер ===
# Секрет для аутентификации запросов от админки bazariara.ge
# Должен совпадать с SCRAPER_WEBHOOK_SECRET в .env bazariara.ge
SCRAPER_WEBHOOK_SECRET=change-me-strong-secret
WEBHOOK_PORT=8080

# === Gorgia.ge ===
# Пусто = полный обход через sitemap
# GORGIA_CATEGORY_URLS=https://gorgia.ge/ka/ikeas-produqcia/

# === Поведение ===
REQUEST_DELAY=1.5
MAX_RETRIES=3
CONCURRENT_SCRAPERS=3
PRICE_CHANGE_THRESHOLD=0.05
