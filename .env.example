# === Neon PostgreSQL ===
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# === Vercel Blob ===
# Vercel Dashboard → Storage → Blob Store → токен
VERCEL_BLOB_TOKEN=vercel_blob_rw_xxx

# === Telegram ===
# Создай бота через @BotFather
TELEGRAM_BOT_TOKEN=1234567890:AAF-xxx
# ID чата — узнать через @userinfobot
TELEGRAM_CHAT_ID=123456789

# === Gorgia категории ===
# Пусто = все категории из scrapers/gorgia.py
# Конкретные URL через запятую — для выборочного запуска:
# GORGIA_CATEGORY_URLS=https://gorgia.ge/ka/ikeas-produqcia/ikeas-aveji/ikeas-magidebi-da-merxebi/

# === Настройки ===
REQUEST_DELAY=1.5
MAX_RETRIES=3
